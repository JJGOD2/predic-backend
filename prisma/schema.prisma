generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ────────────────────────────────────────────
model User {
  id                  String   @id @default(uuid())
  username            String   @unique @db.VarChar(20)
  email               String   @unique @db.VarChar(255)
  phone               String?  @db.VarChar(20)
  passwordHash        String   @map("password_hash")
  avatarUrl           String?  @map("avatar_url")
  bio                 String?

  score               BigInt   @default(1000)
  gem                 Int      @default(0)
  ntdBalance          Decimal  @default(0) @map("ntd_balance") @db.Decimal(12, 2)

  isPro               Boolean   @default(false) @map("is_pro")
  proExpiresAt        DateTime? @map("pro_expires_at")
  proNotifEnabled     Boolean   @default(true) @map("pro_notif_enabled")

  status              String    @default("active") @db.VarChar(20)
  emailVerified       Boolean   @default(false) @map("email_verified")
  phoneVerified       Boolean   @default(false) @map("phone_verified")
  refreshTokenVersion Int       @default(0) @map("refresh_token_version")
  lastLoginAt         DateTime? @map("last_login_at")

  referralCode        String?   @unique @map("referral_code") @db.VarChar(20)
  referredByCode      String?   @map("referred_by_code") @db.VarChar(20)

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  trades              Trade[]
  notifications       Notification[]
  comments            MarketComment[]
  checkins            UserCheckin[]
  dailyTasks          DailyTask[]
  inventory           UserInventory[]
  proSubs             ProSubscription[]
  pushSubs            PushSubscription[]
  referralsGiven      ReferralReward[] @relation("referrer")
  referralsReceived   ReferralReward[] @relation("referee")
  lotteryDrawLogs     LotteryDrawLog[]

  @@index([status])
  @@index([referralCode])
  @@map("users")
}

model Market {
  id                  String    @id @default(uuid())
  slug                String    @unique @db.VarChar(100)
  category            String    @db.VarChar(30)
  icon                String    @db.VarChar(10)
  tag                 String?   @db.VarChar(30)
  question            String
  description         String?

  yesPct              Decimal   @default(50) @map("yes_pct") @db.Decimal(5, 2)

  status              String    @default("open") @db.VarChar(20)
  resolution          String?   @db.VarChar(10)
  resolutionSource    String?   @map("resolution_source")

  volumeScore         BigInt    @default(0) @map("volume_score")
  participantCount    Int       @default(0) @map("participant_count")
  sortScore           Decimal   @default(0) @map("sort_score") @db.Decimal(14, 4)

  endsAt              DateTime  @map("ends_at")
  resolvedAt          DateTime? @map("resolved_at")

  isHot               Boolean   @default(false) @map("is_hot")
  isSponsored         Boolean   @default(false) @map("is_sponsored")
  sponsorName         String?   @map("sponsor_name") @db.VarChar(100)
  communityThreshold  Int       @default(2000) @map("community_threshold")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  trades              Trade[]
  comments            MarketComment[]
  probHistory         ProbabilityLog[]

  @@index([category])
  @@index([status])
  @@index([endsAt])
  @@index([isHot])
  @@index([isSponsored])
  @@index([sortScore])
  @@map("markets")
}

model Trade {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  marketId          String    @map("market_id")
  direction         String    @db.VarChar(3)
  mode              String    @default("buy") @db.VarChar(10)
  amount            BigInt
  remainingAmount   BigInt?   @map("remaining_amount")
  entryPct          Decimal   @map("entry_pct") @db.Decimal(5, 2)
  status            String    @default("open") @db.VarChar(20)
  pnl               BigInt?
  settledAt         DateTime? @map("settled_at")
  closedAt          DateTime? @map("closed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  market            Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([marketId])
  @@index([status])
  @@index([userId, marketId])
  @@index([userId, marketId, direction, status])
  @@index([createdAt(sort: Desc)])
  @@map("trades")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   @db.VarChar(30)
  icon      String   @db.VarChar(10)
  title     String   @db.VarChar(100)
  body      String
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  isPushed  Boolean  @default(false) @map("is_pushed")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, type])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model MarketComment {
  id        String   @id @default(uuid())
  marketId  String   @map("market_id")
  userId    String   @map("user_id")
  content   String
  likes     Int      @default(0)
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([userId])
  @@map("market_comments")
}

model ProbabilityLog {
  id         String   @id @default(uuid())
  marketId   String   @map("market_id")
  yesPct     Decimal  @map("yes_pct") @db.Decimal(5, 2)
  recordedAt DateTime @default(now()) @map("recorded_at")

  market     Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, recordedAt])
  @@map("probability_log")
}

model UserCheckin {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  date        DateTime @db.Date
  streak      Int      @default(1)
  rewardScore Int      @default(10) @map("reward_score")
  rewardGem   Int      @default(0) @map("reward_gem")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("user_checkins")
}

model DailyTask {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  date          DateTime  @db.Date
  taskKey       String    @map("task_key") @db.VarChar(50)
  progress      Int       @default(0)
  target        Int       @default(1)
  completedAt   DateTime? @map("completed_at")
  rewardClaimed Boolean   @default(false) @map("reward_claimed")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, taskKey])
  @@index([userId, date])
  @@map("daily_tasks")
}

model UserInventory {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  itemKey     String   @map("item_key") @db.VarChar(50)
  quantity    Int      @default(1)
  acquiredAt  DateTime @default(now()) @map("acquired_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemKey])
  @@index([userId])
  @@map("user_inventory")
}

model ShopItem {
  id              String   @id @default(uuid())
  key             String   @unique @db.VarChar(50)
  name            String   @db.VarChar(100)
  description     String?
  type            String   @db.VarChar(20)
  currency        String   @db.VarChar(10)
  price           Decimal  @db.Decimal(12, 2)
  rewardItemKey   String?  @map("reward_item_key") @db.VarChar(50)
  rewardQuantity  Int      @default(1) @map("reward_quantity")
  rewardGem       Int      @default(0) @map("reward_gem")
  rewardScore     BigInt   @default(0) @map("reward_score")
  rewardTickets   Int      @default(0) @map("reward_tickets")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([type, isActive])
  @@index([sortOrder])
  @@map("shop_items")
}

model LotteryPrize {
  id             String   @id @default(uuid())
  key            String   @unique @db.VarChar(50)
  name           String   @db.VarChar(100)
  description    String?
  rarity         String   @db.VarChar(20)
  stock          Int?
  weight         Int      @default(1)
  rewardType     String   @map("reward_type") @db.VarChar(20)
  rewardItemKey  String?  @map("reward_item_key") @db.VarChar(50)
  rewardQuantity Int      @default(1) @map("reward_quantity")
  rewardGem      Int      @default(0) @map("reward_gem")
  rewardScore    BigInt   @default(0) @map("reward_score")
  rewardProDays  Int      @default(0) @map("reward_pro_days")
  isActive       Boolean  @default(true) @map("is_active")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  drawLogs       LotteryDrawLog[]

  @@index([isActive, sortOrder])
  @@index([rarity])
  @@map("lottery_prizes")
}

model LotteryDrawLog {
  id            String       @id @default(uuid())
  userId        String       @map("user_id")
  prizeId       String       @map("prize_id")
  ticketCost    Int          @default(1) @map("ticket_cost")
  drawnAt       DateTime     @default(now()) @map("drawn_at")

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  prize         LotteryPrize @relation(fields: [prizeId], references: [id], onDelete: Restrict)

  @@index([userId, drawnAt(sort: Desc)])
  @@index([prizeId])
  @@map("lottery_draw_logs")
}

model ProSubscription {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  plan        String   @db.VarChar(20)
  priceNtd    Decimal  @map("price_ntd") @db.Decimal(8, 2)
  startsAt    DateTime @map("starts_at")
  expiresAt   DateTime @map("expires_at")
  status      String   @default("active") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("pro_subscriptions")
}

model PushSubscription {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  endpoint     String   @unique
  p256dh       String
  auth         String
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model ReferralReward {
  id           String   @id @default(uuid())
  referrerId   String   @map("referrer_id")
  refereeId    String   @map("referee_id")
  rewardScore  Int      @map("reward_score")
  createdAt    DateTime @default(now()) @map("created_at")

  referrer     User     @relation("referrer", fields: [referrerId], references: [id])
  referee      User     @relation("referee", fields: [refereeId], references: [id])

  @@index([referrerId])
  @@index([refereeId])
  @@map("referral_rewards")
}
