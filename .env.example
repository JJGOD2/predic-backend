# ─────────────────────────────────────────────────────
# Predic Backend — 環境變數設定
# 複製此檔案為 .env，填入你的實際值
# 部署到 Zeabur 時，在 Variables 頁面設定這些值
# ─────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# ── Database (Zeabur 會自動注入 DATABASE_URL) ─────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/predic

# ── Redis (Zeabur 會自動注入 REDIS_URL) ───────────────
REDIS_URL=redis://HOST:6379

# ── JWT (務必換成隨機字串，最少 32 字元) ─────────────
JWT_ACCESS_SECRET=your-super-secret-key-change-this-now-32chars
JWT_REFRESH_SECRET=another-super-secret-key-change-this-too
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── CORS (前端網址，多個用逗號分隔) ─────────────────
CORS_ORIGINS=https://predic.tw,https://www.predic.tw

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# ── Email (選填，沒設定的話 OTP 只會 console.log) ────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@predic.tw

# ── Web Push VAPID (選填，用於 PRO 推播通知) ─────────
# 用 npx web-push generate-vapid-keys 產生
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:dev@predic.tw

# ── OAuth 登入 (需要設定才能使用 Google/LINE 登入) ─────
# Google OAuth - 在 Google Cloud Console 取得
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://your-frontend.com/auth/callback/google

# LINE OAuth - 在 LINE Developers Console 取得
# LINE_CHANNEL_ID=
# LINE_CHANNEL_SECRET=
# LINE_REDIRECT_URI=https://your-frontend.com/auth/callback/line
